# Secrets
.env

# Per-server generated build context + rendered env (regenerated from bench.config.yaml)
servers/**/.src/
servers/**/.env

# Terraform — state and local cache are machine-specific.
# NOTE: .terraform.lock.hcl IS committed (it pins provider versions = reproducibility).
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfplan
infra/crash.log

# Generated dataset + snapshots (regenerated deterministically from seed)
dataset/output/
dataset/snapshots/

# Run artifacts (uploaded to Blob; not tracked)
results/
results-blob/
*.log

# Synthea jar (174MB — generate.sh downloads the pinned version)
dataset/*.jar

# Remote-run wiring (generated from Terraform outputs).
# .detached*.env hold real VM public IPs (LOADGEN_IP/SUT_IP) — never commit them.
# The glob covers the sequential .detached.env AND parallel .detached.s1.env/.s2.env.
.remote.env
.detached*.env

# Python bytecode cache
__pycache__/
*.pyc
.detached-run.sh
