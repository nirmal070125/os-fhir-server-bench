# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.

# ── Azure auth ───────────────────────────────────────────────────────────────
# ARM_SUBSCRIPTION_ID is ALWAYS required:
ARM_SUBSCRIPTION_ID=
#
# Then pick ONE auth mode:
#
# Mode 1 — Azure CLI (simplest; no service principal needed).
#   `az login` as a user with Contributor on the subscription, set
#   ARM_SUBSCRIPTION_ID above, and leave ARM_CLIENT_* below blank. Terraform uses
#   your CLI session. Best when you can't create app registrations in your tenant.
#
# Mode 2 — Service principal (used by CI; needs directory rights to create it):
#   az ad sp create-for-rbac --name os-fhir-server-bench \
#     --role Contributor --scopes /subscriptions/$ARM_SUBSCRIPTION_ID
#   then fill all three (appId/tenant/password -> CLIENT_ID/TENANT_ID/CLIENT_SECRET):
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# ── Azure Blob for result artifacts ──────────────────────────────────────────
# Storage account is created by Terraform; the run reads these to upload results.
BENCH_STORAGE_ACCOUNT=
BENCH_STORAGE_KEY=
BENCH_BLOB_CONTAINER=bench-results

# ── Optional ─────────────────────────────────────────────────────────────────
# Only if you pull a private server image (our published image is public).
GHCR_TOKEN=
