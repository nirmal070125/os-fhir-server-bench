# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.

# ── Azure service principal ──────────────────────────────────────────────────
# The azurerm Terraform provider reads these ARM_* vars automatically.
# Create one with:
#   az ad sp create-for-rbac --name os-fhir-server-bench \
#     --role Contributor --scopes /subscriptions/<SUB_ID>
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# ── Azure Blob for result artifacts ──────────────────────────────────────────
# Storage account is created by Terraform; the run reads these to upload results.
BENCH_STORAGE_ACCOUNT=
BENCH_STORAGE_KEY=
BENCH_BLOB_CONTAINER=bench-results

# ── Optional ─────────────────────────────────────────────────────────────────
# Only if you pull a private server image (our published image is public).
GHCR_TOKEN=
